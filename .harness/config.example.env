# Copy to .harness/config.env and fill in.
# All values are project-specific; nothing in .harness/ should hardcode them.

PROJECT_NAME="{{project-name}}"
PACKAGE_MANAGER="{{npm|yarn|pnpm|bun}}"

# Each command must exit 0 on success. Replace with your project's tooling.
LINT_CMD="{{lint command, e.g. 'pnpm lint'}}"
TYPECHECK_CMD="{{typecheck command, e.g. 'pnpm tsc --noEmit'}}"
TEST_CMD="{{test command, e.g. 'pnpm test --run'}}"

DEFAULT_AGENT="claude-code"
DEFAULT_MODEL="{{model id used for cost attribution}}"

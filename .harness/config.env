# Project-specific configuration for the Outer Harness.
# Sourced by .harness/init.sh, .harness/gates/run-gates.sh, .harness/hooks/on-stop.sh.
# Keep this file committed; copy from config.example.env when bootstrapping a new repo.

PROJECT_NAME="dating"
PACKAGE_MANAGER="bun"

# Commands run by gates/run-gates.sh. Each must exit 0 on success.
LINT_CMD="bun lint"
TYPECHECK_CMD="bunx tsc --noEmit"
TEST_CMD="echo 'no tests configured' && exit 0"

# Default agent identity stamped into runs.jsonl when the on-stop hook fires.
DEFAULT_AGENT="claude-code"
DEFAULT_MODEL="claude-opus-4-6"
